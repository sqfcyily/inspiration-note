{
  "name": "inspiration-note",
  "version": "1.0.0",
  "description": "A sleek, modern desktop sticky note application built with Electron and SQLite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.8.0",
    "marked": "^12.0.1",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.inspiration.note",
    "productName": "灵感便签",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "src/assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "灵感便签"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!node_modules/better-sqlite3/build/Release/*.obj",
      "!node_modules/better-sqlite3/src/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/better-sqlite3/**/*.node"
    ]
  }
}
